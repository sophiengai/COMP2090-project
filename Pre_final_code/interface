        input("Press Enter to continue...")

def borrower_login():
    print("\n--- Borrower Login ---")
    borrower_id = input("Enter borrower ID (e.g., B001): ")
    
    borrower = data.find_borrower_by_id(borrower_id)
    if borrower:
        print(f"Welcome, {borrower['name']}!")
        borrower_menu(borrower_id)
    else:
        print("Borrower ID not found!")
        input("Press Enter to continue...")

def borrower_menu(borrower_id):
    while True:
        print("\n" + "-"*40)
        print("    Borrower Menu")
        print("-"*40)
        print("1. Search Books")
        print("2. Borrow Book")
        print("3. Return Book")
        print("4. Renew Book")
        print("5. View My Borrowing Records")
        print("6. Back to Main Menu")
        print("-"*40)
        
        choice = input("Please select (1-6): ")
        
        if choice == "1":
            borrower.search_books(borrower_id)
        elif choice == "2":
            print("[Notice] Borrow Book function - Pending integration")
            Borrow = borrower.Borrower(borrower_id)
            Borrow.borrow_avaliable()
        elif choice == "3":
            print("[Notice] Return Book function - Pending integration")
            Return = borrower.Borrower(borrower_id)
            Return.return_avaliable()
        elif choice == "4":
            print("[Notice] Renew Book function - Pending integration")
            Renew = borrower.Borrower(borrower_id)
            Renew.renew_avaliable()
        elif choice == "5":
            borrower.show_my_records(borrower_id)
        elif choice == "6":
            break
        else:
            print("Invalid choice")
        
        input("Press Enter to continue...")


if __name__ == "__main__":
    main_menu()
