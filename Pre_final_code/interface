def manager_menu():
    while True:
        print("\n" + "-"*40)
        print("    Manager Menu")
        print("-"*40)
        print("1. Add Book")
        print("2. Delete Book")
        print("3. Update Book Information")
        print("4. Manage Borrower Information")
        print("5. Back to Main Menu")
        print("-"*40)
        
        choice = input("Please select (1-5): ")
        
        if choice == "1":
            print("[Notice] Add Book function - Pending integration")
            Add = manager.Manager()
            Add.add_books()
        elif choice == "2":
            print("[Notice] Delete Book function - Pending integration")
            Delete = manager.Manager()
            Delete.delete_book_avaliable()
        elif choice == "3":
            print("[Notice] Update Book function - Pending integration")
            Update = manager.Manager()
            Update.update_book_avaliable()
        elif choice == "4":
